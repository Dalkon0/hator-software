{
  "name": "hator-app",
  "version": "1.0.0",
  "description": "HATOR Gaming Software",
  "main": "main.js",
  "author": "HATOR Gaming",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.hator.software",
    "productName": "HATOR Software",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icons/icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "node-hid": "^3.1.0"
  }
}
